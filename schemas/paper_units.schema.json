{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Paper Units",
  "type": "object",
  "required": ["paper_id", "units"],
  "properties": {
    "paper_id": {
      "type": "string"
    },
    "paper_metadata": {
      "type": ["object", "null"],
      "properties": {
        "title": {
          "type": ["string", "null"]
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "year": {
          "type": ["integer", "null"]
        },
        "venue": {
          "type": ["string", "null"]
        },
        "arxiv_id": {
          "type": ["string", "null"]
        },
        "doi": {
          "type": ["string", "null"]
        },
        "source_url": {
          "type": ["string", "null"]
        },
        "markdown_path": {
          "type": ["string", "null"]
        }
      }
    },
    "status": {
      "type": ["string", "null"]
    },
    "unit_count": {
      "type": ["integer", "null"]
    },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "text", "sources"],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "enum": [
              "research_question",
              "core_claim",
              "method",
              "formal_conclusion",
              "evidence",
              "limitation",
              "assumption",
              "scope",
              "resource"
            ]
          },
          "text": {
            "type": "string"
          },
          "summary": {
            "type": ["string", "null"]
          },
          "supports": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_type": {
            "type": ["string", "null"]
          },
          "scope_data": {
            "type": ["object", "null"],
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          },
          "resource_type": {
            "type": ["string", "null"]
          },
          "resource_name": {
            "type": ["string", "null"]
          },
          "resource_role": {
            "type": ["string", "null"]
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["section_hint", "quote"],
              "properties": {
                "section_hint": {
                  "type": ["string", "null"]
                },
                "quote": {
                  "type": "string"
                }
              }
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
