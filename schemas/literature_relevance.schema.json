{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LiteratureRelevanceBatch",
  "type": "object",
  "required": ["scores"],
  "properties": {
    "scores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["paper_id", "score"],
        "properties": {
          "paper_id": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
