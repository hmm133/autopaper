{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LiteratureSearchRequest",
  "type": "object",
  "required": ["topic_description"],
  "properties": {
    "topic_description": {
      "type": "string",
      "minLength": 1
    },
    "start_date": {
      "type": ["string", "null"]
    },
    "end_date": {
      "type": ["string", "null"]
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "search_intent": {
      "type": ["string", "null"]
    },
    "candidate_limit": {
      "type": "integer",
      "minimum": 1
    },
    "top_k": {
      "type": ["integer", "null"],
      "minimum": 1
    }
  },
  "additionalProperties": false
}
